  "admissions": {
    "general_admission": "Graduate admission is selective and requires a bachelor’s degree from a recognized college or university plus distinct academic ability and motivation.",
    "required_documents": [
      "One recent passport-size photo.",
      "Copy of identity card or passport.",
      "Family Civil Status record for Lebanese and Arab nationals.",
      "Certified copies of educational or professional certificates or diplomas.",
      "Official updated university transcripts from all universities attended, with course descriptions of completed courses.",
      "Equivalency of the bachelor’s degree from the Lebanese Ministry of Higher Education, when applicable.",
      "Certified copy of the official secondary diploma and any required Lebanese equivalence.",
      "Two professor recommendations; employment certificate if the applicant has work experience.",
      "W-9S form and proof of Social Security Number for U.S. citizens or U.S. Green Card holders."
    ],
    "english_requirements": {
      "tests": [
        {
          "test": "TOEFL iBT",
          "minimum_score": 90
        },
        {
          "test": "IELTS",
          "minimum_score": 7
        },
        {
          "test": "EEE",
          "minimum_score": 123
        },
        {
          "test": "Duolingo English Test",
          "minimum_score": 125
        }
      ],
      "conditional_rules": [
        "EEE scores between 102 and 122, or equivalent TOEFL/IELTS/Duolingo scores, require ENG601 or a retake of the English test within the first year of enrollment.",
        "Applicants below EEE 102, TOEFL iBT 80, IELTS 6.5, or Duolingo 115 are not accepted into graduate programs.",
        "English proficiency may not be required for applicants from LAU-recognized universities where the language of instruction is English."
      ]
    },
