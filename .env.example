# ----- Additional properties from Server/src/main/resources/application.properties
# JWT settings
JWT_EXPIRATION_MS=86400000

# Mail server (defaults mirror application.properties)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587

# Spring datasource (the app reads these values)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/uniai
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}

# Optional application settings
SPRING_APPLICATION_NAME=uniai
SERVER_PORT=9090

# Email Settings - ALL required
MAIL_FROM=noreply@uniai.com
EMAIL_CODE_EXPIRY_MINUTES=15
EMAIL_CODE_LENGTH=6
EMAIL_SUPPORT_URL=mailto:support@uniai.com
