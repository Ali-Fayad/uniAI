  "admissions": {
    "summary": "Graduate admissions are handled by the Office of Admissions. Applicants must meet university and faculty requirements; departments and faculties supervise the criteria.",
    "source_ids": [
      "uob_grad_admissions",
      "uob_admission_guide_pdf"
    ]
  },
  "required_documents": {
    "summary": "The reviewed graduate admissions sources explicitly list a certified copy of diploma, two recommendation letters, diploma equivalence if applicable, and an official transcript with course descriptions for completed courses.",
    "source_ids": [
      "uob_admission_guide_pdf"
    ]
  },
  "english_requirement": {
    "summary": "English-track graduate majors require EPT 85 or TOEFL iBT 100 (or paper-based TOEFL 600). Applicants below the threshold may be admitted conditionally and complete ENGL101/ENGL102 during the first year. French-track majors require FREN201, with DELF/DALF-based placement rules.",
    "source_ids": [
      "uob_grad_admissions",
      "uob_admission_guide_pdf"
    ]
  },
  "deadlines": {
    "summary": "No single centralized graduate application deadline page was identified. The university asks applicants to monitor the website for updates and the academic calendar lists semester timing, registration, and exam periods.",
    "source_ids": [
      "uob_grad_admissions",
      "uob_admission_guide_pdf",
      "uob_academic_calendar"
    ]
  },
  "scholarships": {
    "summary": "The financial support pages mention merit scholarships, athletic scholarships, faculty support, and graduate assistantship as support categories. Graduate-specific award tables were not published in the reviewed sources.",
    "source_ids": [
      "uob_financial_support",
      "uob_admission_guide_pdf"
    ]
  },
  "financial_aid": {
    "summary": "UOB states it allocates part of its annual budget to support student tuition fees based on academic excellence and the social situation of the student. The financial support page also references financial aid applications and graduate assistantship.",
    "source_ids": [
      "uob_financial_support",
      "uob_admission_guide_pdf"
    ]
  },
  "payment_plans": {
    "summary": "The reviewed official sources do not publish a dedicated installment-plan page. The fee sheet states payment is made in cash at the cashier’s office, late installment payment triggers an additional charge, and a refund schedule is provided for withdrawals.",
    "source_ids": [
      "uob_fees_expenses_pdf"
    ]
  },
  "academic_calendar": {
    "summary": "The official academic calendar page and the graduate catalogue publish the current semester timing, registration windows, drop/add periods, and exam periods.",
    "source_ids": [
      "uob_academic_calendar",
      "uob_general_graduate_catalogue_pdf"
    ]
  },
  "academic_regulations": {
    "summary": "Graduate academic regulations published in the catalogue require a full-time load of 9-12 credits per semester, allow transfer credits up to 40%, require a minimum cumulative average of 80, and publish the graduate grading scheme.",
    "source_ids": [
      "uob_general_graduate_catalogue_pdf",
      "uob_grading_policy_faq"
    ]
  },
  "accreditation": {
    "summary": "UOB states in the admissions guide that it is accredited by multiple higher educational commissions. The Faculty of Engineering hub also highlights ABET and ACQUIN accreditation markers.",
    "source_ids": [
      "uob_admission_guide_pdf",
      "uob_foe"
    ]
  },
  "international_students": {
    "summary": "UOB states it admits students from Lebanon and the region at large without discrimination and also welcomes international students from 55 countries. The admissions materials provide international-student guidance through the university admissions flow.",
    "source_ids": [
      "uob_admission_guide_pdf",
      "uob_grad_admissions"
    ]
  },
  "language_policy": {
    "summary": "UOB follows the American System of Liberal Education, with some programs offered in French. The graduate catalogue lists faculty language settings: FAS English/French/Arabic, Business English, Engineering English, Health Sciences English/French, Medicine English, ALBA English/French, and Theology Arabic/English/Greek.",
    "source_ids": [
      "uob_admission_guide_pdf",
      "uob_general_graduate_catalogue_pdf"
    ]
  },
