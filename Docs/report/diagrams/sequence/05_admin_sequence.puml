@startuml
title Administration Flow
skinparam shadowing false
skinparam sequenceArrowThickness 1
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 120

actor Administrator
boundary AdminDashboardPage
participant adminService
boundary AdminController
control AdminApplicationService
entity UserRepository
entity FeedbackRepository
entity ChatRepository
database PostgreSQL

Administrator -> AdminDashboardPage : open dashboard
AdminDashboardPage -> adminService : load overview
adminService -> AdminController : GET admin overview
AdminController -> AdminApplicationService : getOverview()
AdminApplicationService -> UserRepository : count users
UserRepository -> PostgreSQL : COUNT users
AdminApplicationService -> ChatRepository : count chats/messages
ChatRepository -> PostgreSQL : COUNT chats/messages
AdminApplicationService -> FeedbackRepository : count feedback
FeedbackRepository -> PostgreSQL : COUNT feedback
PostgreSQL --> AdminApplicationService : statistics
AdminApplicationService --> AdminController : overview response
AdminController --> adminService : JSON overview
adminService --> AdminDashboardPage : render statistics

opt Search users
  Administrator -> AdminDashboardPage : enter email search
  AdminDashboardPage -> adminService : searchUsers(email)
  adminService -> AdminController : GET users?email=...
  AdminController -> AdminApplicationService : searchUsersByEmail(email)
  AdminApplicationService -> UserRepository : searchByEmail(email)
  UserRepository -> PostgreSQL : SELECT matching users
  PostgreSQL --> UserRepository : users
  UserRepository --> AdminApplicationService : users
  AdminApplicationService --> AdminController : search results
  AdminController --> adminService : JSON users
  adminService --> AdminDashboardPage : render users
end

opt Update role
  Administrator -> AdminDashboardPage : choose role
  AdminDashboardPage -> adminService : updateRole(userId, role)
  adminService -> AdminController : PUT user role
  AdminController -> AdminApplicationService : updateUserRole(actor, target, role)
  AdminApplicationService -> UserRepository : load actor and target
  UserRepository -> PostgreSQL : SELECT users
  PostgreSQL --> UserRepository : users
  alt Self-demotion
    AdminApplicationService --> AdminController : SelfDemotionNotAllowedException
  else Last administrator protection
    AdminApplicationService -> UserRepository : countByRole(ADMIN)
    UserRepository -> PostgreSQL : COUNT administrators
    PostgreSQL --> UserRepository : count = 1
    AdminApplicationService --> AdminController : LastAdminProtectionException
  else Valid role update
    AdminApplicationService -> UserRepository : save(target with new role)
    UserRepository -> PostgreSQL : UPDATE users
    AdminApplicationService --> AdminController : refreshed user details
  end
  AdminController --> adminService : response/error
end

opt Delete user
  Administrator -> AdminDashboardPage : delete user
  AdminDashboardPage -> adminService : deleteUser(userId)
  adminService -> AdminController : DELETE user
  AdminController -> AdminApplicationService : deleteUser(actor, target)
  AdminApplicationService -> UserRepository : load actor and target
  alt Self deletion
    AdminApplicationService --> AdminController : SelfDeleteNotAllowedException
  else Target is last administrator
    AdminApplicationService -> UserRepository : countByRole(ADMIN)
    AdminApplicationService --> AdminController : LastAdminProtectionException
  else Valid deletion
    AdminApplicationService -> FeedbackRepository : deleteByUserId(target)
    FeedbackRepository -> PostgreSQL : DELETE feedback
    AdminApplicationService -> UserRepository : delete(target)
    UserRepository -> PostgreSQL : DELETE user
    AdminApplicationService --> AdminController : success
  end
  AdminController --> adminService : response/error
end

opt Delete feedback
  Administrator -> AdminDashboardPage : delete feedback
  AdminDashboardPage -> adminService : deleteFeedback(feedbackId)
  adminService -> AdminController : DELETE feedback
  AdminController -> AdminApplicationService : deleteFeedback(feedbackId)
  AdminApplicationService -> FeedbackRepository : findById(feedbackId)
  FeedbackRepository -> PostgreSQL : SELECT feedback
  alt Feedback missing
    AdminApplicationService --> AdminController : FeedbackNotFoundException
  else Feedback found
    AdminApplicationService -> FeedbackRepository : deleteById(feedbackId)
    FeedbackRepository -> PostgreSQL : DELETE feedback
    AdminApplicationService --> AdminController : success
  end
  AdminController --> adminService : response/error
end
@enduml
