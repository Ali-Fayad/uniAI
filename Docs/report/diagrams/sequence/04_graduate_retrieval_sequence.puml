@startuml
title Graduate Knowledge Retrieval Flow
skinparam shadowing false
skinparam sequenceArrowThickness 1
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 120

participant GraduateRoutePlannerPort
control GraduateRouteEntityResolver
participant GraduateRoutePlan
participant GraduateRouteHandler
participant typed route DAO adapters
participant GraduateCatalogRouteHandler
participant SqlGraduateCatalogRouteDao
control GraduateCitationEngine
database PostgreSQL

GraduateRoutePlannerPort -> GraduateRoutePlannerPort : normalize message
GraduateRoutePlannerPort -> GraduateRouteEntityResolver : detect resource/operation/scope
GraduateRouteEntityResolver --> GraduateRoutePlannerPort : structured signals
GraduateRoutePlannerPort -> GraduateRouteEntityResolver : resolve university aliases/location
GraduateRouteEntityResolver --> GraduateRoutePlannerPort : resolved entities and filters
GraduateRoutePlannerPort -> GraduateRoutePlan : construct normalized query

alt Ambiguous or unsupported query
  GraduateRoutePlannerPort --> GraduateRouteHandler : no retrieval; clarification state
else Location resource (CAMPUS or UNIVERSITY)
  GraduateRoutePlannerPort -> GraduateCatalogRouteHandler : retrieveContext(query)
  GraduateCatalogRouteHandler -> SqlGraduateCatalogRouteDao : choose location SQL
  alt COUNT
    SqlGraduateCatalogRouteDao -> PostgreSQL : SELECT COUNT(DISTINCT ...)
  else EXISTS
    SqlGraduateCatalogRouteDao -> PostgreSQL : SELECT EXISTS(...)
    opt Matching evidence exists
      SqlGraduateCatalogRouteDao -> PostgreSQL : SELECT one bounded evidence row
    end
  else LIST
    SqlGraduateCatalogRouteDao -> PostgreSQL : SELECT bounded campus/university rows
  else COMPARE campus counts
    SqlGraduateCatalogRouteDao -> PostgreSQL : GROUP BY university, COUNT(DISTINCT campus)
  end
  PostgreSQL --> SqlGraduateCatalogRouteDao : rows or scalar result
  SqlGraduateCatalogRouteDao --> GraduateCatalogRouteHandler : structured location context
  GraduateCatalogRouteHandler --> GraduateRoutePlannerPort : retrieval result
else Academic resource (PROGRAM/FACULTY/DEPARTMENT)
  GraduateRoutePlannerPort -> GraduateRouteHandler : retrieveContext(query)
  GraduateRouteHandler -> typed route DAO adapters : academic SQL branch
  alt Program list/details
    typed route DAO adapters -> PostgreSQL : SELECT programs and requested projections
  else Program count/exists
    typed route DAO adapters -> PostgreSQL : COUNT(DISTINCT graduate_program)
  else Faculty or department count/exists
    typed route DAO adapters -> PostgreSQL : COUNT(DISTINCT academic entity)
  end
  PostgreSQL --> typed route DAO adapters : academic rows/scalar
  typed route DAO adapters --> GraduateRouteHandler : formatted academic context
  GraduateRouteHandler --> GraduateRoutePlannerPort : retrieval result
else Tuition aggregation
  GraduateRoutePlannerPort -> GraduateRouteHandler : retrieveContext(query)
  GraduateRouteHandler -> typed route DAO adapters : tuition aggregation branch
  typed route DAO adapters -> PostgreSQL : grouped tuition aggregate SQL
  PostgreSQL --> typed route DAO adapters : tuition aggregates and source URLs
  typed route DAO adapters --> GraduateRouteHandler : tuition context
  GraduateRouteHandler --> GraduateRoutePlannerPort : retrieval result
end

alt No data
  GraduateCitationEngine -> GraduateCitationEngine : preserve explicit missing-data context
else Citations available
  GraduateCitationEngine -> GraduateCitationEngine : format citation instructions
end
GraduateRoutePlannerPort --> GraduateCitationEngine : normalized query and retrieval result
GraduateCitationEngine --> GraduateRoutePlannerPort : formatted context/citation metadata
@enduml
