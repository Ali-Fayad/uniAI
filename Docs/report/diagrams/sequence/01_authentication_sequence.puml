@startuml
title Authentication Flow
skinparam shadowing false
skinparam sequenceArrowThickness 1
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 120

actor Visitor
boundary Frontend
boundary AuthController
control AuthApplicationService
participant PasswordEncoder
participant JwtUtil
participant NotificationPort
participant EmailNotificationAdapter
entity UserRepository
entity VerifyCodeRepository
database PostgreSQL

Visitor -> Frontend : submit registration/sign-in/verification form
Frontend -> AuthController : HTTP request
activate AuthController

alt Register
  AuthController -> AuthApplicationService : signUp(command)
  activate AuthApplicationService
  AuthApplicationService -> UserRepository : existsByEmail(email)
  UserRepository -> PostgreSQL : SELECT duplicate email
  PostgreSQL --> UserRepository : result
  AuthApplicationService -> UserRepository : existsByUsername(username)
  UserRepository -> PostgreSQL : SELECT duplicate username
  PostgreSQL --> UserRepository : result
  alt Email already exists
    AuthApplicationService --> AuthController : AlreadyExistsException
  else Username already exists
    AuthApplicationService --> AuthController : AlreadyExistsException
  else Valid registration
    AuthApplicationService -> PasswordEncoder : encode(password)
    PasswordEncoder --> AuthApplicationService : hash
    AuthApplicationService -> UserRepository : save(user with USER/first ADMIN role)
    UserRepository -> PostgreSQL : INSERT users
    PostgreSQL --> UserRepository : persisted user
    AuthApplicationService -> VerifyCodeRepository : invalidate previous code
    AuthApplicationService -> VerifyCodeRepository : save registration code
    VerifyCodeRepository -> PostgreSQL : INSERT verification code
    AuthApplicationService -> NotificationPort : send verification email
    NotificationPort ..> EmailNotificationAdapter : dispatch
    EmailNotificationAdapter --> Visitor : email containing code
    AuthApplicationService --> AuthController : verification required
  end
  deactivate AuthApplicationService

else Verify email or 2FA
  AuthController -> AuthApplicationService : verifyEmail()/verifyTwoFactor(command)
  activate AuthApplicationService
  AuthApplicationService -> VerifyCodeRepository : find code by email/type
  VerifyCodeRepository -> PostgreSQL : SELECT code and expiry
  PostgreSQL --> VerifyCodeRepository : code
  alt Invalid or expired code
    AuthApplicationService --> AuthController : InvalidVerificationCodeException
  else Valid code
    AuthApplicationService -> VerifyCodeRepository : mark code used
    AuthApplicationService -> JwtUtil : generateToken(user payload)
    JwtUtil --> AuthApplicationService : JWT
    AuthApplicationService --> AuthController : JWT
  end
  deactivate AuthApplicationService

else Sign in
  AuthController -> AuthApplicationService : signIn(command)
  activate AuthApplicationService
  AuthApplicationService -> UserRepository : findByEmail(email)
  UserRepository -> PostgreSQL : SELECT user
  PostgreSQL --> UserRepository : user/not found
  alt Unknown email or incorrect password
    AuthApplicationService -> PasswordEncoder : matches(password, hash)
    PasswordEncoder --> AuthApplicationService : false
    AuthApplicationService --> AuthController : InvalidEmailOrPassword
  else User not verified
    AuthApplicationService -> NotificationPort : send registration code
    NotificationPort ..> EmailNotificationAdapter : dispatch
    AuthApplicationService --> AuthController : verification required
  else Two-factor authentication enabled
    AuthApplicationService -> VerifyCodeRepository : save TWO_FA code
    AuthApplicationService -> NotificationPort : send 2FA email
    NotificationPort ..> EmailNotificationAdapter : dispatch
    AuthApplicationService --> AuthController : code sent
  else Verified password
    AuthApplicationService -> JwtUtil : generateToken(user payload)
    JwtUtil --> AuthApplicationService : JWT
    AuthApplicationService --> AuthController : JWT
  end
  deactivate AuthApplicationService

else Password reset
  AuthController -> AuthApplicationService : forgotPassword(email)
  AuthApplicationService -> UserRepository : findByEmail(email)
  UserRepository -> PostgreSQL : SELECT user
  PostgreSQL --> UserRepository : user
  AuthApplicationService -> VerifyCodeRepository : save PASSWORD_RESET code
  AuthApplicationService -> NotificationPort : send reset email
  NotificationPort ..> EmailNotificationAdapter : dispatch
  AuthController --> Frontend : reset code requested
  Frontend -> AuthController : confirmPasswordReset(command)
  AuthController -> AuthApplicationService : confirmPasswordReset(command)
  AuthApplicationService -> VerifyCodeRepository : validate PASSWORD_RESET code
  alt Invalid or expired reset code
    AuthApplicationService --> AuthController : InvalidVerificationCodeException
  else Valid reset code
    AuthApplicationService -> PasswordEncoder : encode(new password)
    AuthApplicationService -> UserRepository : save(updated user)
    AuthApplicationService -> JwtUtil : generateToken(user payload)
    JwtUtil --> AuthApplicationService : JWT
    AuthApplicationService --> AuthController : JWT
  end
end

AuthController --> Frontend : HTTP response
deactivate AuthController
Frontend --> Visitor : display result
@enduml
