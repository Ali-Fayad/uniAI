@startuml
title AI / Graduate Knowledge Database ERD (Logical View)

left to right direction
hide methods
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam entity {
  BackgroundColor #FDFDFD
  BorderColor #374151
  FontColor #111827
  AttributeFontSize 9
  FontSize 10
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #64748B
  FontColor #0F172A
  FontSize 11
}
skinparam note {
  BackgroundColor #FFF7ED
  BorderColor #C2410C
  FontSize 9
}

' ============================================================================
' Shared/reference dimensions and knowledge geography
' ============================================================================
package "Knowledge Geography" {
  entity university <<Shared>> {
    * id : BIGSERIAL <<PK>>
    --
    name : VARCHAR(255) <<NOT NULL>>
    name_ar : VARCHAR(255)
    acronym : VARCHAR(20)
    country : VARCHAR(120)
    city : VARCHAR(120)
    latitude : DECIMAL(10,8)
    longitude : DECIMAL(11,8)
    campus_name : VARCHAR(255)
    campus_type : VARCHAR(50)
    --
    UQ (name, campus_name)
  }

  entity university_faculty {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    name : VARCHAR(255) <<NOT NULL>>
    short_name : VARCHAR(255)
    faculty_type : VARCHAR(50) <<NOT NULL, enum>>
    official_url : TEXT
    notes : TEXT
    --
    UQ (university_id, name)
  }

  entity university_department {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    short_name : VARCHAR(255)
    official_url : TEXT
    notes : TEXT
    --
    UQ (university_id, faculty_id, name)
  }
}

package "Academic Dimensions" {
  entity degree_type <<Shared>> {
    * id : BIGSERIAL <<PK>>
    --
    code : VARCHAR(50) <<NOT NULL, UQ>>
    name : VARCHAR(255) <<NOT NULL, UQ>>
  }

  entity language <<Shared>> {
    * id : BIGSERIAL <<PK>>
    --
    name : VARCHAR(255) <<NOT NULL, UQ>>
    code : VARCHAR(16) <<NOT NULL, UQ>>
    native_name : VARCHAR(255)
  }
}

package "Knowledge Sources / Provenance" {
  entity source {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    title : VARCHAR(255) <<NOT NULL>>
    url : TEXT <<NOT NULL>>
    source_type : VARCHAR(50) <<NOT NULL, enum>>
    accessed_at : DATE
    notes : TEXT
    --
    UQ (university_id, url)
  }
}

package "Academic Structure / Current Retrieval Model" {
  entity graduate_program {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    degree_type_id : BIGINT <<FK, optional>>
    primary_language_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    program_key : VARCHAR(255) <<NOT NULL>>
    major_category : VARCHAR(255)
    major : VARCHAR(255)
    official_degree_name : VARCHAR(255)
    thesis_or_non_thesis : VARCHAR(50) <<enum>>
    credits : INTEGER
    duration_value : NUMERIC(10,2)
    duration_unit : VARCHAR(30) <<enum>>
    delivery_mode : VARCHAR(30) <<enum>>
    program_description : TEXT
    official_program_url : TEXT
    notes : TEXT
    --
    UQ (university_id, program_key)
    UQ (university_id, official_program_url)
  }

  entity graduate_program_alias {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    program_id : BIGINT <<FK, NOT NULL>>
    source_id : BIGINT <<FK, optional>>
    alias_type : VARCHAR(50) <<NOT NULL, enum>>
    alias : VARCHAR(255) <<NOT NULL>>
    note : TEXT
    --
    UQ (university_id, alias_type, alias)
  }

  entity graduate_program_track {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    program_id : BIGINT <<FK, NOT NULL>>
    source_id : BIGINT <<FK, NOT NULL>>
    track_type : VARCHAR(50) <<NOT NULL, enum>>
    track_name : VARCHAR(255) <<NOT NULL>>
    track_order : INTEGER
    is_primary : BOOLEAN <<NOT NULL>>
    description : TEXT
    notes : TEXT
    --
    UQ (program_id, track_type, track_name)
  }

  entity graduate_program_source <<Mapping>> {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    program_id : BIGINT <<FK, NOT NULL>>
    source_id : BIGINT <<FK, NOT NULL>>
    source_role : VARCHAR(50) <<NOT NULL, enum>>
    source_order : INTEGER <<NOT NULL>>
    evidence_text : TEXT
    notes : TEXT
    --
    UQ (program_id, source_id, source_role)
  }

  entity graduate_program_relationship <<Mapping>> {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    program_id : BIGINT <<FK, NOT NULL>>
    related_program_id : BIGINT <<FK, NOT NULL>>
    relation_type : VARCHAR(50) <<NOT NULL, enum>>
    note : TEXT
    --
    UQ (program_id, related_program_id, relation_type)
  }
}

package "Program Metadata / Tuition" {
  entity graduate_tuition_rate {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20) <<NOT NULL>>
    currency : VARCHAR(10) <<NOT NULL>>
    billing_basis : VARCHAR(30) <<NOT NULL, enum>>
    amount : NUMERIC(12,2) <<NOT NULL>>
    category : VARCHAR(255) <<NOT NULL>>
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_fee_item {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20)
    fee_name : VARCHAR(255) <<NOT NULL>>
    billing_basis : VARCHAR(30) <<NOT NULL, enum>>
    currency : VARCHAR(10) <<NOT NULL>>
    amount : NUMERIC(12,2)
    category : VARCHAR(255)
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_scholarship {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20)
    name : VARCHAR(255) <<NOT NULL>>
    coverage : TEXT
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    description : TEXT
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_financial_aid {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20)
    name : VARCHAR(255) <<NOT NULL>>
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    description : TEXT
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_payment_plan {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20)
    name : VARCHAR(255) <<NOT NULL>>
    installments_count : INTEGER
    down_payment_amount : NUMERIC(12,2)
    down_payment_currency : VARCHAR(10)
    interval_label : VARCHAR(100)
    description : TEXT
    notes : TEXT
    --
    UQ (university_id, record_key)
  }
}

package "Admissions / Requirements" {
  entity graduate_admission_requirement {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    requirement_type : VARCHAR(50) <<NOT NULL, enum>>
    requirement_text : TEXT <<NOT NULL>>
    comparison_operator : VARCHAR(10)
    threshold_value : NUMERIC(12,2)
    threshold_unit : VARCHAR(50)
    is_required : BOOLEAN <<NOT NULL>>
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_required_document {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    document_type : VARCHAR(100) <<NOT NULL>>
    document_name : VARCHAR(255) <<NOT NULL>>
    is_optional : BOOLEAN <<NOT NULL>>
    sort_order : INTEGER
    notes : TEXT
    --
    UQ (university_id, record_key)
  }

  entity graduate_admission_deadline {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    academic_year : VARCHAR(20)
    deadline_type : VARCHAR(50) <<NOT NULL, enum>>
    term : VARCHAR(100)
    deadline_date : DATE
    note : TEXT
    --
    UQ (university_id, record_key)
  }
}

package "Knowledge Sources / Accreditation" {
  entity graduate_accreditation {
    * id : BIGSERIAL <<PK>>
    --
    university_id : BIGINT <<FK, NOT NULL>>
    faculty_id : BIGINT <<FK, optional>>
    department_id : BIGINT <<FK, optional>>
    program_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, NOT NULL>>
    --
    scope_level : VARCHAR(20) <<NOT NULL, enum>>
    record_key : TEXT <<NOT NULL>>
    name : VARCHAR(255) <<NOT NULL>>
    authority : VARCHAR(255)
    status : VARCHAR(100)
    valid_from : DATE
    valid_until : DATE
    notes : TEXT
    --
    UQ (university_id, record_key)
  }
}

' V23 tables remain physically present for compatibility, but are not read by
' the current SQL graduate retrieval adapters. They are shown explicitly.
package "Legacy Graduate Compatibility (V23)" #E5E7EB {
  entity major_category <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    name : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    --
    UQ (university_id, name)
  }
  entity major <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_category_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    --
    UQ (university_id, major_category_id, name)
  }
  entity major_degree <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_id : BIGINT <<FK, optional>>
    degree_type_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    duration_value : INTEGER
    duration_unit : VARCHAR(50)
    description : TEXT
    --
    UQ (university_id, name)
  }
  entity tuition_fee <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    period : VARCHAR(50)
    note : TEXT
  }
  entity fee_item <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    tuition_fee_id : BIGINT <<FK, NOT NULL>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    note : TEXT
    --
    UQ (tuition_fee_id, name)
  }
  entity admission_requirement <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    requirement_type : VARCHAR(100)
    requirement_text : TEXT <<NOT NULL>>
    sort_order : INTEGER
  }
  entity required_document <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    admission_requirement_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    is_optional : BOOLEAN <<NOT NULL>>
    sort_order : INTEGER
    --
    UQ (admission_requirement_id, name)
  }
  entity admission_deadline <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    deadline_type : VARCHAR(100)
    term : VARCHAR(100)
    deadline_date : DATE
    note : TEXT
  }
  entity scholarship <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    coverage : TEXT
    description : TEXT
    --
    UQ (university_id, name)
  }
  entity financial_aid <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    amount : NUMERIC(12,2)
    currency : VARCHAR(10)
    description : TEXT
    --
    UQ (university_id, name)
  }
  entity payment_plan <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    installments_count : INTEGER
    description : TEXT
    --
    UQ (university_id, name)
  }
  entity accreditation <<Legacy>> {
    * id : BIGSERIAL <<PK>>
    university_id : BIGINT <<FK, NOT NULL>>
    major_degree_id : BIGINT <<FK, optional>>
    source_id : BIGINT <<FK, optional>>
    name : VARCHAR(255) <<NOT NULL>>
    authority : VARCHAR(255)
    status : VARCHAR(100)
    valid_from : DATE
    valid_until : DATE
  }
}

